{
  "name": "timefrontiers/api-auth-client",
  "description": "Client library for signing TimeFrontiers API requests",
  "type": "library",
  "license": "MIT",
  "version": "1.0.0",
  "keywords": ["api", "authentication", "hmac", "client", "signing"],
  "authors": [
    {
      "name": "TimeFrontiers",
      "email": "dev@timefrontiers.com"
    }
  ],
  "require": {
    "php": ">=8.1"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0"
  },
  "autoload": {
    "psr-4": {
      "TimeFrontiers\\Auth\\Client\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "TimeFrontiers\\Auth\\Client\\Tests\\": "tests/"
    }
  },
  "config": {
    "sort-packages": true
  },
  "minimum-stability": "stable"
}
